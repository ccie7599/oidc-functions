# Override any Spin variable with SPIN_VARIABLE_<NAME> (UPPERCASE).
# The defaults in spin.toml already target the local Keycloak demo, so you only
# need this file to point at a real IdP. Source it before `spin up`:  set -a; . .env; set +a

# --- Example: real Okta (custom authz server) ---
# SPIN_VARIABLE_ISSUER=https://your-org.okta.com/oauth2/aus.../
# SPIN_VARIABLE_CLIENT_ID=0oa...
# SPIN_VARIABLE_CLIENT_SECRET=...
# SPIN_VARIABLE_REDIRECT_URI=http://localhost:3000/callback
# SPIN_VARIABLE_ADMIN_GROUP=cp-admins
# SPIN_VARIABLE_SCOPES=openid profile email groups

# --- Example: real PingOne ---
# SPIN_VARIABLE_ISSUER=https://auth.pingone.com/<envID>/as
# SPIN_VARIABLE_CLIENT_ID=...
# SPIN_VARIABLE_CLIENT_SECRET=...

# --- Always override these in any non-demo deployment ---
# SPIN_VARIABLE_CP_FORWARD_SECRET=$(openssl rand -hex 32)
